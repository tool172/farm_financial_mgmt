<?php

/**
 * @file
 * Farm Financial Management — ranch income and expense tracking.
 *
 * Built on purpose-built content entities (financial_transaction +
 * financial_line, both RevisionableContentEntityBase) rather than the farmOS
 * log model. Lifecycle logic and hooks live in OOP hook classes under
 * src/Hook/ using PHP 8 #[Hook] attributes (matching farm_grazing_rotation_plan),
 * so this file is intentionally minimal.
 */

declare(strict_types=1);

/**
 * Implements hook_menu_links_discovered_alter().
 *
 * Hides the Tax Summary link when tax planning is turned off in settings. The
 * route is also access-gated; this keeps the link out of the toolbar (which
 * caches aggressively). SettingsForm rebuilds menu links when the toggle
 * changes so this re-runs.
 */
function farm_financial_mgmt_menu_links_discovered_alter(array &$links): void {
  $config = \Drupal::config('farm_financial_mgmt.settings');
  $basic = (bool) ($config->get('basic_mode') ?? FALSE);

  // Basic mode: income/expense only — hide the whole tax & capital-accounting
  // apparatus (reports, depreciation, balance sheet, enterprise P&L, liabilities).
  if ($basic) {
    foreach ([
      'farm_financial_mgmt.report.tax_summary',
      'farm_financial_mgmt.report.depreciation',
      'farm_financial_mgmt.report.form_4797',
      'farm_financial_mgmt.report.enterprise_pl',
      'farm_financial_mgmt.report.balance_sheet',
      'farm_financial_mgmt.depreciable_assets',
      'farm_financial_mgmt.liabilities',
      'farm_financial_mgmt.depreciation_limits',
    ] as $id) {
      unset($links[$id]);
    }
    return;
  }

  // Full mode: the tax-planning sub-toggle still hides just the tax reports.
  $tax_enabled = $config->get('tax_planning_enabled') ?? TRUE;
  if (!$tax_enabled) {
    unset($links['farm_financial_mgmt.report.tax_summary']);
    // The depreciation schedule and Form 4797 are tax-facing and tax-gated, so
    // hide their links alongside the Tax Summary.
    unset($links['farm_financial_mgmt.report.depreciation']);
    unset($links['farm_financial_mgmt.report.form_4797']);
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for the transaction add form.
 *
 * Prefill entry point for the Sales & Intake bridge: a "Record income/expense"
 * link (from farm_ranch_ui) opens this form with ?ffm_direction=income|expense
 * and ?ffm_asset={animal id}. Sets the direction, and surfaces the animal to
 * link on a line (the inline line widget is button-based, so its asset field
 * can't be pre-populated before the operator adds a line).
 */
function farm_financial_mgmt_form_financial_transaction_add_form_alter(array &$form, \Drupal\Core\Form\FormStateInterface $form_state, string $form_id): void {
  // Only on a fresh build, and only when the prefill params are present.
  if ($form_state->isSubmitted() || $form_state->getUserInput()) {
    return;
  }
  $query = \Drupal::request()->query;
  if (!$query->has('ffm_direction') && !$query->has('ffm_asset')) {
    return;
  }

  $direction = (string) $query->get('ffm_direction');
  if (in_array($direction, ['income', 'expense'], TRUE) && isset($form['direction']['widget'])) {
    $form['direction']['widget']['#default_value'] = $direction;
  }

  $asset_id = (int) $query->get('ffm_asset');
  if ($asset_id > 0) {
    $asset = \Drupal::entityTypeManager()->getStorage('asset')->load($asset_id);
    if ($asset !== NULL) {
      $form['ffm_prefill_note'] = [
        '#weight' => -50,
        '#markup' => '<div class="messages messages--status">'
          . t('Recording for <strong>@label</strong> — add a line below and select this animal so the entry links back to it.', ['@label' => $asset->label()])
          . '</div>',
      ];
    }
  }
}

/**
 * Implements hook_theme().
 */
function farm_financial_mgmt_theme(): array {
  return [
    'financial_dashboard' => [
      'variables' => [
        'year' => NULL,
        'currency' => 'USD',
        'income' => '0.00',
        'expense' => '0.00',
        'net' => '0.00',
        'income_by_category' => [],
        'spending_by_category' => [],
        'recent' => [],
        'add_url' => NULL,
        'list_url' => NULL,
      ],
    ],
    'financial_report' => [
      'variables' => [
        'report_title' => NULL,
        'currency' => 'USD',
        'year' => NULL,
        'summary' => [],
        'chart_id' => NULL,
        'sections' => [],
        'grids' => [],
        'disclosures' => [],
      ],
    ],
  ];
}
