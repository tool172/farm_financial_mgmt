{#
/**
 * @file
 * Generic financial report layout: summary cards, optional chart, and
 * breakdown sections. Shared by the Phase 2 report controllers.
 */
#}
<div class="financial-report">

  <form class="ffm-report-filter" method="get">
    <label>{{ 'Reporting year'|t }}
      <input type="number" name="year" value="{{ year }}" min="2000" max="2100" />
    </label>
    <button type="submit">{{ 'Apply'|t }}</button>
  </form>

  {% if disclosures %}
    <div class="ffm-disclosures">
      {% for d in disclosures %}<div class="ffm-disclosure">{{ d }}</div>{% endfor %}
    </div>
  {% endif %}

  {% if summary %}
    <div class="ffm-cards">
      {% for c in summary %}
        <div class="ffm-card ffm-card--{{ c.kind }}">
          <div class="ffm-card-label">{{ c.label }}</div>
          <div class="ffm-card-value">{{ currency }} {{ c.value }}</div>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% if chart_id %}
    <div class="ffm-chart-wrap" style="height:260px;">
      <canvas id="{{ chart_id }}"></canvas>
    </div>
  {% endif %}

  {% for section in sections %}
    <h3 class="ffm-heading">{{ section.heading }}</h3>
    {% if section.rows %}
      <table class="ffm-table">
        <thead>
          <tr><th>{{ section.col1|default('Category'|t) }}</th><th class="ffm-num">{{ 'Amount'|t }}</th></tr>
        </thead>
        <tbody>
          {% for row in section.rows %}
            <tr>
              <td>{% if row.url %}<a href="{{ row.url }}">{{ row.label }}</a>{% else %}{{ row.label }}{% endif %}</td>
              <td class="ffm-num">{{ currency }} {{ row.amount }}</td>
            </tr>
          {% endfor %}
          {% if section.total is not null %}
            <tr class="ffm-total"><td>{{ 'Total'|t }}</td><td class="ffm-num">{{ currency }} {{ section.total }}</td></tr>
          {% endif %}
        </tbody>
      </table>
    {% else %}
      <p class="ffm-empty">{{ 'No data for this period.'|t }}</p>
    {% endif %}
  {% endfor %}

  {% for grid in grids %}
    <h3 class="ffm-heading">{{ grid.heading }}</h3>
    {% if grid.rows %}
      <table class="ffm-table">
        <thead>
          <tr>{% for h in grid.headers %}<th class="{{ h.num ? 'ffm-num' }}">{{ h.label }}</th>{% endfor %}</tr>
        </thead>
        <tbody>
          {% for row in grid.rows %}
            <tr class="{{ row.total ? 'ffm-total' }}">
              {% for cell in row.cells %}<td class="{{ cell.num ? 'ffm-num' }}">{% if cell.url %}<a href="{{ cell.url }}">{{ cell.value }}</a>{% else %}{{ cell.value }}{% endif %}</td>{% endfor %}
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p class="ffm-empty">{{ 'No data for this period.'|t }}</p>
    {% endif %}
  {% endfor %}

</div>
